# OpenAI Configuration (required for LLM, optional for STT fallback)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Deepgram Configuration (default STT provider — Nova-3 streaming)
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Groq Configuration (default LLM provider — fast battle card generation)
GROQ_API_KEY=your-groq-api-key-here

# LiveKit Configuration
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# Supabase Configuration
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# LLM Configuration (override default from llm_models.yaml)
# LLM_MODEL=gpt-4o

# CORS (comma-separated origins, defaults to * for local dev)
CORS_ORIGINS=https://app.yourdomain.com

# Application Settings
APP_NAME=Dozi
APP_VERSION=0.1.0
DEBUG=false
