# OpenAI Configuration (required for LLM, optional for STT fallback)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Groq Configuration (default LLM provider — fast battle card generation)
GROQ_API_KEY=your-groq-api-key-here

# LiveKit Configuration
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# Auth — JWKS endpoint for JWT validation only (e.g. your Supabase project URL)
AUTH_JWKS_URL=https://xxxxx.supabase.co

# CORS — JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000","https://app.yourdomain.com"]

# Application Settings
APP_NAME=Dozi
APP_VERSION=0.1.0
DEBUG=false
